# Frontend dev URL (Vite)
VITE_API_URL=http://localhost:3002/api

# Server
PORT=3002
# Lista CSV de origens permitidas (ex: https://capivari.com,https://www.capivari.com)
FRONTEND_ORIGIN=http://localhost:5173
# Defina como "true" se atras de proxy/load balancer (nginx, cloudflare)
TRUST_PROXY=false

# JWT — gerar com: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# Mínimo 32 caracteres, NÃO usar placeholder
JWT_SECRET=
JWT_EXPIRES_IN=2h

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=
DB_NAME=capivaridb

# Admin inicial (seed) — senha mínimo 12 chars, forte
ADMIN_EMAIL=admin@capivari.local
ADMIN_PASSWORD=
ADMIN_NAME=Admin Capivari

# Rate limit (opcional — defaults: 10min janela, 5 tentativas, 10min ban)
LOGIN_RATE_WINDOW_MS=600000
LOGIN_RATE_MAX_ATTEMPTS=5
LOGIN_BAN_MS=600000
